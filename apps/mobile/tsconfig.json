{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "types": [],
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnosticSeverity": {
          "globalDate": "off",
          "globalConsole": "off",
          "globalRandom": "off",
          "globalTimers": "off",
          "globalFetch": "off"
        }
      }
    ]
  },
  "include": ["src", "App.tsx"]
}
