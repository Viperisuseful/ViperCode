{
  "expo": {
    "name": "Viper Code",
    "slug": "viper-code",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "vipercode",
    "userInterfaceStyle": "automatic",
    "platforms": ["android"],
    "android": {
      "package": "com.vipercode.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1117"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "clerkPublishableKey": "${EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY}",
      "clerkJwtTemplate": "${EXPO_PUBLIC_CLERK_JWT_TEMPLATE}",
      "relayUrl": "${EXPO_PUBLIC_VIPERCODE_RELAY_URL}"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Viper Code to access your camera to scan pairing QR codes."
        }
      ]
    ]
  }
}
