# Optional: Viper Connect source builds
# Leave these unset to disable optional Viper Connect features in local source builds.
# Release builds inject their public values at build time. Do not add server-side
# secrets to this file.

# Get these from the Clerk Dashboard under API keys, JWT templates, and OAuth applications.
# VIPERCODE_CLERK_PUBLISHABLE_KEY=pk_test_...
# VIPERCODE_CLERK_JWT_TEMPLATE=viper-relay
# VIPERCODE_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...

# Get this from your relay deployment. `infra/relay` deploys update it automatically.
# VIPERCODE_RELAY_URL=https://relay.example.com

# Public, ingest-only mobile OpenTelemetry configuration.
# VIPERCODE_MOBILE_OTLP_TRACES_URL=https://api.axiom.co/v1/traces
# VIPERCODE_MOBILE_OTLP_TRACES_DATASET=viper-code-mobile-traces-dev
# VIPERCODE_MOBILE_OTLP_TRACES_TOKEN=xaat-...
